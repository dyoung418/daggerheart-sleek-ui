<div class="tabs loadout-tab">
  {{!-- LOADOUT --}}
  <div class="category-wrapper {{#if (contains @root.collapsedCategories 'loadout')}}collapsed{{/if}}" data-category-id="loadout">

  <div class="category-header" data-action="toggleCategory">
    <h2>{{localize "DAGGERHEART.GENERAL.Tabs.loadout"}}</h2>
    <span class="loadout-number">({{document.system.loadoutSlot.current}}/{{document.system.loadoutSlot.max}})</span>
    <span class="create-btn">
      <a data-action="addNewItem" data-document-class="Item" data-type="domainCard" data-tooltip="Create">
        <i class="fa-solid fa-plus icon-button" style=""></i>
      </a>
    </span>
    <span class="line"></span>
    <i class="fa-solid fa-chevron-down"></i>
  </div>

  <div class="category-content">
    {{#each loadoutCards as |cardData|}}
      {{> "modules/daggerheart-sleek-ui/templates/components/card-domains.hbs"
          item=cardData.item
          tags=cardData.tags
          hopeCost=cardData.hopeCost
          usesData=cardData.usesData
          ownershipLevel=@root.ownershipLevel}}
    {{/each}}
  </div>

  </div>

  {{!-- VAULT --}}
  <div class="category-wrapper {{#if (contains @root.collapsedCategories 'vault')}}collapsed{{/if}}" data-category-id="vault">

  <div class="category-header" data-action="toggleCategory">
    <h2>{{localize "DAGGERHEART.GENERAL.Tabs.vault"}}</h2>
    <span class="create-btn">
      <a data-action="addNewItem" data-document-class="Item" data-type="domainCard" data-in-vault="true" data-tooltip="Create">
        <i class="fa-solid fa-plus icon-button" style=""></i>
      </a>
    </span>
      
    <span class="line"></span>
    <i class="fa-solid fa-chevron-down"></i>
  </div>

  <div class="category-content">
    {{#each vaultCards as |cardData|}}
     {{> "modules/daggerheart-sleek-ui/templates/components/card-domains.hbs"
          item=cardData.item
          tags=cardData.tags
          hopeCost=cardData.hopeCost
          usesData=cardData.usesData
          ownershipLevel=@root.ownershipLevel}}
     {{/each}}
  </div>

  </div>
</div>