<div class="card-wrapper actor-attack">

  <div class="card-container header">

    <div class="card-icon" data-action="useActorAttack">
      <img
        class="icon"
        src="{{document.system.attack.img}}"
        alt="{{document.system.attack.name}}"
      />
      {{#if @root.isNPC}}
        <img
          class="dice-roll"
          src="systems/daggerheart/assets/icons/dice/default/d20.svg"
          alt="d20"
        />
      {{else}}
        <img
          class="dice-roll"
          src="systems/daggerheart/assets/icons/dice/duality/DualityBW.svg"
          alt="2d12"
        />
      {{/if}}
    </div>

    <div class="card-header">

      <div class="card-text">
        <span class="card-text-name">{{document.system.attack.name}}</span>
        <span class="card-text-details">
          {{localize
            (concat
              "DAGGERHEART.CONFIG.Range." document.system.attack.range ".name"
            )
          }}
        </span>
      </div>

      <div class="card-resource">
        <div
          class="card-resource roll-damage actor-attack-roll"
          data-tooltip="DAGGERHEART.GENERAL.rollDamage"
        >
          {{attackDamage}}
          &nbsp;
          {{#if (contains attackDamageType "magical")}}
            <i class="fa-solid fa-wand-sparkles"></i>
          {{else}}
            <i class="fa-solid fa-hand-fist"></i>
          {{/if}}
        </div>
      </div>

    </div>

  </div>

</div>