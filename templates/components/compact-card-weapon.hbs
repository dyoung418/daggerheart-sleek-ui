<div
  class="compact card-wrapper weapon"
  draggable="true"
  data-item-uuid="{{item.uuid}}"
>

  <div
    class="card-container header"
    data-item-uuid="{{item.uuid}}"
    data-type="weapon"
    data-action="navigateToCard"
  >

    <div class="card-icon" data-action="useItem" data-item-uuid="{{item.uuid}}">
      <img class="icon" src="{{item.img}}" alt="{{item.name}}" />
      <img
        class="duality-dice"
        src="systems/daggerheart/assets/icons/dice/duality/DualityBW.svg"
        alt=""
      />
    </div>

    <div class="card-header">

      <div class="card-text">
        <span class="card-text-name">{{item.name}}</span>
        <span class="card-text-details">
          {{localize
            (concat
              "DAGGERHEART.CONFIG.Traits."
              item.system.attack.roll.trait
              ".short"
            )
          }}
          <span class="separator"></span>
          {{localize
            (concat
              "DAGGERHEART.CONFIG.Range." item.system.attack.range ".short"
            )
          }}
          <span class="separator"></span>
          {{{damage}}}
        </span>
      </div>

      <div class="card-resource">
      </div>

      <div class="hover-area">

        <div class="hover-resources">

          <div
            class="roll-damage"
            data-item-uuid="{{item.uuid}}"
            data-action="item.system.attack"
            data-tooltip="DAGGERHEART.GENERAL.rollDamage"
          >
            <i class="fa-solid fa-dice"></i>
          </div>

        </div>

      </div>

    </div>

  </div>

</div>